# Supabase 연결 시크릿 템플릿
# ─────────────────────────────────────────────────────────────
# 사용법:
#   1) 이 파일을 .streamlit/secrets.toml 로 복사
#        cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2) Supabase Project Settings → API 의 값으로 채우기
#   3) 배포 시에는 Streamlit Cloud → App settings → Secrets 에 동일 내용 붙여넣기
#   ※ secrets.toml 은 절대 git에 커밋하지 말 것 (.gitignore에 등록됨)
# ─────────────────────────────────────────────────────────────

[connections.supabase]
url = "https://your-project-ref.supabase.co"
key = "your-anon-public-key"
